{
  "name": "simplewallet",
  "version": "1.0.0",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "patch-package",
    "refactor:stats": "node scripts/update-refactor-progress.js stats",
    "refactor:start": "node scripts/update-refactor-progress.js start",
    "refactor:complete": "node scripts/update-refactor-progress.js complete",
    "refactor:block": "node scripts/update-refactor-progress.js block",
    "refactor:unblock": "node scripts/update-refactor-progress.js unblock",
    "refactor:note": "node scripts/update-refactor-progress.js note",
    "e2e": "maestro test e2e/maestro/flows/",
    "e2e:auth": "maestro test e2e/maestro/flows/auth/",
    "e2e:wallet": "maestro test e2e/maestro/flows/wallet/",
    "e2e:send": "maestro test e2e/maestro/flows/send/",
    "e2e:smoke": "maestro test e2e/maestro/flows/auth/01-create-wallet.yaml e2e/maestro/flows/auth/03-pin-unlock.yaml e2e/maestro/flows/wallet/01-view-balance.yaml",
    "e2e:studio": "maestro studio",
    "e2e:reset": "xcrun simctl uninstall booted com.ducatprotocol.DucatProtocolWallet",
    "e2e:iphone16pro": "e2e/maestro/scripts/run-iphone16pro.sh",
    "bundle:analyze": "EXPO_PUBLIC_BUNDLE_ANALYZE=1 npx expo export --platform ios 2>&1 | tail -20",
    "bundle:stats": "npx react-native-bundle-visualizer",
    "deadcode": "npx knip",
    "deadcode:fix": "npx knip --fix"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
