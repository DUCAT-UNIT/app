{
  "name": "simplewallet",
  "version": "1.0.0",
  "main": "index.tsx",
  "scripts": {
    "start": "node scripts/run-node22.mjs expo start",
    "android": "node scripts/run-node22.mjs expo run:android",
    "ios": "node scripts/run-node22.mjs expo run:ios",
    "web": "node scripts/run-node22.mjs expo start --web",
    "doctor": "node scripts/doctor.mjs",
    "doctor:live": "node scripts/liveIntegrationDoctor.mjs",
    "cold-install:audit": "node scripts/coldInstallAudit.mjs",
    "history:audit": "node scripts/historyAudit.mjs",
    "perf:audit": "node scripts/performanceTrace.mjs",
    "release:doctor": "node scripts/releaseDoctor.mjs",
    "typecheck": "node scripts/run-node22.mjs tsc --noEmit",
    "typecheck:watch": "node scripts/run-node22.mjs tsc --noEmit --watch",
    "lint": "node scripts/run-node22.mjs eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "node scripts/run-node22.mjs eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "guard:cleanup": "node scripts/cleanupGuard.mjs",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "node scripts/run-node22.mjs jest",
    "test:watch": "node scripts/run-node22.mjs jest --watch",
    "test:coverage": "node scripts/run-node22.mjs jest --coverage",
    "test:cleanup": "node scripts/run-node22.mjs jest screens/settings/__tests__/quantaLinkUtils.test.ts services/liquidation/__tests__/math.test.ts services/liquidation/__tests__/calculations.test.ts services/vault/__tests__/vault.test.ts --runInBand",
    "verify": "npm run doctor && npm run typecheck && npm run lint -- --quiet && npm run guard:cleanup && npm run deadcode -- --reporter compact && npm run e2e:validate && npm run test:coverage -- --runInBand --silent",
    "verify:quick": "npm run typecheck && npm run lint -- --quiet && npm run guard:cleanup",
    "verify:cleanup": "npm run verify:quick && npm run test:cleanup",
    "postinstall": "patch-package",
    "refactor:stats": "node scripts/update-refactor-progress.js stats",
    "refactor:start": "node scripts/update-refactor-progress.js start",
    "refactor:complete": "node scripts/update-refactor-progress.js complete",
    "refactor:block": "node scripts/update-refactor-progress.js block",
    "refactor:unblock": "node scripts/update-refactor-progress.js unblock",
    "refactor:note": "node scripts/update-refactor-progress.js note",
    "e2e": "bash e2e/maestro/run-all-sequential.sh",
    "e2e:auth": "maestro test e2e/maestro/flows/auth/",
    "e2e:wallet": "maestro test e2e/maestro/flows/wallet/",
    "e2e:send": "node scripts/runMaestroCritical.mjs e2e/maestro/flows/send/",
    "e2e:settings": "maestro test e2e/maestro/flows/settings/",
    "e2e:vault": "maestro test e2e/maestro/flows/vault/",
    "e2e:ecash": "maestro test e2e/maestro/flows/ecash/",
    "e2e:live": "npm run doctor:live && node scripts/runMaestroLive.mjs e2e/maestro/flows/test/",
    "e2e:live:turbo": "npm run doctor:live && node scripts/runMaestroLive.mjs e2e/maestro/flows/test/live-turbounit-smoke.yaml",
    "e2e:critical": "node scripts/runMaestroCritical.mjs",
    "e2e:smoke": "maestro test e2e/maestro/flows/auth/01-create-wallet.yaml e2e/maestro/flows/wallet/03-funded-balance.yaml e2e/maestro/flows/settings/01-navigate-settings.yaml",
    "e2e:validate": "node scripts/validateE2EFlows.mjs",
    "e2e:studio": "maestro studio",
    "e2e:reset": "xcrun simctl uninstall booted com.ducatprotocol.DucatProtocolWallet",
    "e2e:iphone16pro": "e2e/maestro/scripts/run-iphone16pro.sh",
    "bundle:analyze": "EXPO_PUBLIC_BUNDLE_ANALYZE=1 npx expo export --platform ios 2>&1 | tail -20",
    "bundle:stats": "npx react-native-bundle-visualizer",
    "deadcode": "node scripts/run-node22.mjs knip",
    "deadcode:fix": "node scripts/run-node22.mjs knip --fix"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@cashu/cashu-ts": "^4.1.0",
    "@cmdcode/buff": "^2.2.5",
