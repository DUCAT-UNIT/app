{
  "expo": {
    "name": "DUCAT",
    "slug": "ducat-wallet",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/logos/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "ducat",
    "splash": {
      "image": "./assets/logos/ducat-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#111015"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ducatprotocol.DucatProtocolWallet",
      "buildNumber": "22",
      "associatedDomains": [
        "webcredentials:ducatprotocol.com",
        "applinks:ducatprotocol.com"
      ],
      "usesIcloudStorage": true,
      "entitlements": {
        "com.apple.developer.icloud-container-environment": "Production",
        "com.apple.developer.icloud-container-identifiers": [
          "iCloud.com.ducatprotocol.DucatProtocolWallet"
        ],
        "com.apple.developer.ubiquity-kvstore-identifier": "$(TeamIdentifierPrefix)$(CFBundleIdentifier)"
      },
      "infoPlist": {
        "UIDeviceFamily": [
          1
        ],
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "NSFaceIDUsageDescription": "We use Face ID to securely authenticate and protect your wallet.",
        "NSCameraUsageDescription": "DUCAT uses the camera to scan wallet addresses, payment requests, and e-cash tokens.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/adaptive-icon.png",
        "backgroundColor": "#111015"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ducatprotocol.DucatProtocolWallet"
    },
    "web": {
      "favicon": "./assets/logos/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logos/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DUCAT to use the camera to scan wallet addresses, payment requests, and e-cash tokens."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ffbcd1c0-efeb-449f-bdfc-009dd286125e"
      }
    },
    "owner": "ducat-protocol-inc"
  }
}
