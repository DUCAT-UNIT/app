{
  "expo": {
    "name": "DUCAT",
    "slug": "SimpleWallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logos/ducat-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#111015"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.SimpleWallet",
      "buildNumber": "25",
      "associatedDomains": [
        "webcredentials:ducatprotocol.com"
      ],
      "usesIcloudStorage": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch",
          "remote-notification",
          "fetch"
        ],
        "NSFaceIDUsageDescription": "We use Face ID to securely authenticate and protect your wallet.",
        "NSCameraUsageDescription": "We need camera access to scan QR codes for sending Bitcoin.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/adaptive-icon.png",
        "backgroundColor": "#111015"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.SimpleWallet"
    },
    "web": {
      "favicon": "./assets/logos/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logos/icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0f1d2d8f-944e-49f8-a48d-bf4c96b96ebb"
      }
    },
    "owner": "zk_bit"
  }
}
