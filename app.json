{
  "expo": {
    "name": "DUCAT",
    "slug": "SimpleWallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logos/ducat-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#111015"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.SimpleWallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/adaptive-icon.png",
        "backgroundColor": "#111015"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.SimpleWallet"
    },
    "web": {
      "favicon": "./assets/logos/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
