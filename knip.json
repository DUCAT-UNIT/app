{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["App.tsx"],
  "project": [
    "**/*.{ts,tsx}",
    "!bridge-service/**",
    "!evm/**",
    "!web/pool-dashboard/**",
    "!vendor/**"
  ],
  "ignore": ["**/__tests__/**", "**/*.test.*"],
  "ignoreFiles": [
    "infra/cloudflare-worker-apple-app-site-association.js",
    "metro.config.js",
    "styles/screens/index.ts"
  ],
  "ignoreWorkspaces": [
    "vendor/ducat-unit-core",
    "vendor/ducat-unit-runestone"
  ],
  "ignoreDependencies": [
    "@ducat-unit/client-sdk",
    "@ducat-unit/core",
    "@ducat-unit/runestone",
    "@opentelemetry/api",
    "@scure/btc-signer",
    "@vbyte/btc-dev",
    "buffer",
    "react-dom",
    "websocket-polyfill",
    "zod",
    "@types/*",
    "@jest/globals",
    "jest",
    "jest-expo",
    "@testing-library/*",
    "@vitest/*",
    "vitest",
    "playwright",
    "expect-type",
    "universal-test-renderer",
    "sharp"
  ],
  "ignoreBinaries": [
    "maestro",
    "xcrun",
    "hardhat",
    "tail",
    "react-native-bundle-visualizer",
    "e2e/maestro/scripts/run-iphone16pro.sh"
  ],
  "workspaces": {
    "bridge-service": {
      "entry": ["src/server.ts"],
      "project": ["src/**/*.ts", "../shared/**/*.ts"],
      "ignore": ["src/__tests__/**"]
    },
    "evm": {
      "entry": ["hardhat.config.js", "scripts/**/*.js", "test/**/*.js"],
      "project": ["**/*.js"],
      "ignore": ["artifacts/**", "cache/**", "node_modules/**"],
      "ignoreDependencies": ["@openzeppelin/contracts"]
    },
    "web/pool-dashboard": {
      "entry": ["src/main.ts", "vite.config.ts"],
      "project": ["src/**/*.ts", "vite.config.ts"],
      "ignore": ["dist/**", "node_modules/**"]
    }
  },
  "ignoreExportsUsedInFile": true
}
