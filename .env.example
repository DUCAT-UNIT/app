# Environment Variables Template
# Copy this file to .env and fill in your actual values
# These variables are loaded by Expo using the EXPO_PUBLIC_ prefix

# CoinGecko API Key (for BTC price feeds)
# Get your key at: https://www.coingecko.com/en/api/pricing
EXPO_PUBLIC_COINGECKO_API_KEY=your-coingecko-api-key-here

# Optional: Override default if needed
# EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
