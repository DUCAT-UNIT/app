# IMPORTANT:
# 1. Copy this file to .env
# 2. Replace with your actual API keys
# 3. NEVER commit .env to git (it's in .gitignore)

# Active Bitcoin network.
# Supported values: mutinynet, mainnet
EXPO_PUBLIC_APP_NETWORK=mutinynet

# Optional shared API overrides
EXPO_PUBLIC_ESPLORA_API_URL=https://mutinynet.com/api
EXPO_PUBLIC_EXPLORER_URL=https://mutinynet.com
EXPO_PUBLIC_ORD_API_URL=https://ord-mutinynet.ducatprotocol.com
EXPO_PUBLIC_GUARDIAN_WS_URL=wss://guardian-mutinynet-1.ducatprotocol.com
EXPO_PUBLIC_VAULT_API_URL=https://validator.ducatprotocol.com/api
EXPO_PUBLIC_QUOTE_SERVER_URL=https://quote.ducatprotocol.com
EXPO_PUBLIC_PRICE_SERVER_URL=https://price.ducatprotocol.com
EXPO_PUBLIC_PHONE_URL=https://phone.ducatprotocol.com
EXPO_PUBLIC_FAUCET_URL=https://faucet.ducatprotocol.com/btc/faucet
EXPO_PUBLIC_FEE_RECOMMENDATIONS_URL=https://mempool.space/testnet/api/v1/fees/recommended

# Protocol identifiers
EXPO_PUBLIC_MASTER_CONTRACT_ID=02837661131516ad503dbe0bcf73964244d5f02bc577678ffd3fcbb54f493f36i0
EXPO_PUBLIC_UNIT_RUNE_BLOCK=1527352
EXPO_PUBLIC_UNIT_RUNE_TX=1
EXPO_PUBLIC_UNIT_RUNE_LABEL=DUCAT•UNIT•RUNE
EXPO_PUBLIC_TURBO_MINT_ADDRESS=tb1p7p74tg67aaw94vz2kewzeyuq80x0a65wpgegnat98f5hkcnpfjsqntv2em

# PostHog Analytics (optional — analytics disabled when key is missing)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional Sepolia EVM swap / bridge overrides
EXPO_PUBLIC_SEPOLIA_RPC_URL=
EXPO_PUBLIC_SEPOLIA_USDC_ADDRESS=
EXPO_PUBLIC_WUNIT_ADDRESS=
EXPO_PUBLIC_UNIT_BRIDGE_ROUTER_ADDRESS=
EXPO_PUBLIC_UNIT_USDC_STABLE_POOL_ADDRESS=
EXPO_PUBLIC_UNIT_BRIDGE_API_URL=
