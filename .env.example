# Sentry Configuration
# Get your DSN from: https://sentry.io/settings/projects/your-project/keys/
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Rebrandly API Key for URL shortening (Spectre tokens)
# Get your API key from: https://www.rebrandly.com/
# Free tier: 500 links/month
EXPO_PUBLIC_REBRANDLY_API_KEY=your_rebrandly_api_key_here

# IMPORTANT:
# 1. Copy this file to .env
# 2. Replace with your actual API keys
# 3. NEVER commit .env to git (it's in .gitignore)
