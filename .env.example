# Optional local environment overrides.
# 1. Copy this file to .env only when you need to override public defaults.
# 2. Do not commit .env; local env files are ignored by git.
# 3. Never place mnemonics, private keys, or production credentials here.

# Active Bitcoin network.
# DUCAT mobile is intentionally Mutinynet-only. Leave unset or use mutinynet.
EXPO_PUBLIC_APP_NETWORK=mutinynet

# Optional shared API overrides
EXPO_PUBLIC_VALIDATOR_URL=https://validator-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_RELAY_URL=https://relay-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_RELAY_WS_URL=wss://relay-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_ORACLE_PUBKEY=a12736a47c9e8f20c863bff8c35fa7db2d79875e5812f419799da2e8ec7cd41e
EXPO_PUBLIC_ORACLE_URL=https://oracle-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_TOOLS_URL=https://tools-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_ESPLORA_API_URL=https://explorer-mutinynet.dev.ducatprotocol.com/api
EXPO_PUBLIC_EXPLORER_URL=https://explorer-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_ORD_API_URL=https://ord-mutinynet.ducatprotocol.com
EXPO_PUBLIC_GUARDIAN_WS_URL=wss://guardian-1-mutinynet.dev.ducatprotocol.com/ws
EXPO_PUBLIC_VAULT_API_URL=https://validator-mutinynet.dev.ducatprotocol.com/api
# Optional; defaults to EXPO_PUBLIC_VALIDATOR_URL.
EXPO_PUBLIC_LIQ_VALIDATOR_URL=https://validator-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_CASHU_MINT_URL=https://dev-cashu-mint.ducatprotocol.com
EXPO_PUBLIC_QUOTE_SERVER_URL=https://validator-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_PRICE_SERVER_URL=https://validator-mutinynet.dev.ducatprotocol.com
EXPO_PUBLIC_PHONE_URL=https://phone.ducatprotocol.com
EXPO_PUBLIC_FAUCET_URL=https://faucet.ducatprotocol.com/btc/faucet
EXPO_PUBLIC_FEE_RECOMMENDATIONS_URL=https://mempool.space/testnet/api/v1/fees/recommended

# Protocol identifiers
EXPO_PUBLIC_MASTER_CONTRACT_ID=4c7a39a8e71b5d891fe5321a2e6fc6cf72039c60096ee63f591ecc7ecfaba115
EXPO_PUBLIC_UNIT_RUNE_BLOCK=1527352
