# Optional Sepolia EVM settlement overrides.
# The app ships public Mutinynet/Sepolia defaults for these values; set only to override.
EXPO_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
EXPO_PUBLIC_SEPOLIA_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
EXPO_PUBLIC_WUNIT_ADDRESS=0x139a26fec4786c83888bB2b25E39f656371ed307
