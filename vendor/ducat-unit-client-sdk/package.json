{
  "name": "@ducat-unit/client-sdk",
  "version": "0.25.2",
  "description": "Client SDK for the Ducat Protocol.",
  "author": "Christopher Scott",
  "repository": {
    "type": "git",
    "url": "https://github.com/DUCAT-UNIT/client-sdk"
  },
  "homepage": "https://github.com/DUCAT-UNIT/client-sdk#readme",
  "keywords": [
    "bitcoin",
    "ducat",
    "unit",
    "vault",
    "stablecoin",
    "collateral",
    "psbt"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "unpkg": "./dist/script.js",
  "files": [
    "README.md",
    "LICENSE",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./const": {
      "types": "./dist/const.d.ts",
      "default": "./dist/const.js"
    },
    "./guard": {
      "types": "./dist/module/guard/index.d.ts",
      "default": "./dist/module/guard/index.js"
    },
    "./fetch": {
      "types": "./dist/lib/fetch/index.d.ts",
      "default": "./dist/lib/fetch/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./observe": {
      "types": "./dist/lib/observe/index.d.ts",
      "default": "./dist/lib/observe/index.js"
    },
    "./oracle": {
      "types": "./dist/module/oracle/index.d.ts",
      "default": "./dist/module/oracle/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./vault": {
      "types": "./dist/module/vault/index.d.ts",
      "default": "./dist/module/vault/index.js"
    },
    "./wallet": {
      "types": "./dist/module/wallet/index.d.ts",
      "default": "./dist/module/wallet/index.js"
    },
    "./util": {
      "types": "./dist/util/index.d.ts",
      "default": "./dist/util/index.js"
    }
  },
  "dependencies": {
    "@ducat-unit/core": "^0.22.0",
    "@ducat-unit/runestone": "^2.0.11",
    "@opentelemetry/api": "^1.9.0",
    "@scure/btc-signer": "2.2.0",
    "@vbyte/btc-dev": "2.1.0",
    "@vbyte/buff": "1.1.0",
    "@vbyte/crypto": "^1.0.1",
    "@vbyte/nostr-sdk": "^1.0.1",
    "@vbyte/util": "2.0.0",
    "websocket-polyfill": "^1.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
